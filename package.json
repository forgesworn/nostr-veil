{
  "name": "nostr-veil",
  "version": "0.17.0",
  "description": "Privacy layer for Nostr reputation systems. Groups collectively score trustworthiness using ring signatures -- scores are verifiable but contributors are unidentifiable.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./nip85": {
      "types": "./dist/nip85/index.d.ts",
      "import": "./dist/nip85/index.js"
    },
    "./proof": {
      "types": "./dist/proof/index.d.ts",
      "import": "./dist/proof/index.js"
    },
    "./profiles": {
      "types": "./dist/profiles/index.d.ts",
      "import": "./dist/profiles/index.js"
    }
  },
  "bin": {
    "nostr-veil": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "LICENCE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test:use-cases": "tsx examples/use-cases.ts",
    "test:production-recipes": "tsx examples/production-recipes.ts",
    "test:use-cases:relay": "tsx examples/use-cases-relay.ts",
    "demo": "cd demo && npm run dev",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "nostr",
    "web-of-trust",
    "wot",
    "nip-85",
    "nip85",
    "ring-signatures",
    "lsag",
    "privacy",
    "trust",
    "anonymous",
    "cryptography",
    "secp256k1",
    "decentralised",
    "verifiable"
  ],
  "author": "ForgeSworn",
  "license": "MIT",
  "homepage": "https://forgesworn.github.io/nostr-veil/",
  "repository": {
    "type": "git",
    "url": "https://github.com/forgesworn/nostr-veil"
  },
  "bugs": {
    "url": "https://github.com/forgesworn/nostr-veil/issues"
  },
  "funding": {
    "type": "lightning",
    "url": "lightning:thedonkey@strike.me"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true
  },
  "dependencies": {
    "@forgesworn/ring-sig": "^3.0.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  }
}
