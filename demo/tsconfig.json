{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "nostr-veil": ["../src/index.ts"],
      "nostr-veil/proof": ["../src/proof/index.ts"],
      "nostr-veil/nip85": ["../src/nip85/index.ts"],
      "nostr-veil/identity": ["../src/identity/index.ts"]
    }
  },
  "include": ["src"]
}
